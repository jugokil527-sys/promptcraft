# ── Обязательные ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_from_botfather

# ── Сервер ────────────────────────────────────────────────────────────────────
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# ── Prod: webhook URL (если не задан — бот работает в polling режиме) ──────────
# Пример: https://yourdomain.com или https://your-app.vercel.app
# WEBHOOK_URL=https://yourdomain.com

# ── AI (Google Gemini) ────────────────────────────────────────────────────────
# Получить: https://aistudio.google.com/apikey
# Без ключа работает mock-режим
# GEMINI_API_KEY=your_gemini_key
# GEMINI_MODEL=gemini-2.0-flash

# ── Администраторы бота (через запятую, Telegram user ID) ─────────────────────
# Команды /stats и /broadcast доступны только этим ID
# ADMIN_IDS=123456789,987654321

# ── Vercel ────────────────────────────────────────────────────────────────────
# Автоматически задаётся Vercel — не менять вручную
# VERCEL=1
